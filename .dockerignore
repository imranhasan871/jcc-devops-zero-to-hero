# Exclude these from the Docker build context.
# A smaller build context = faster uploads to the Docker daemon = faster builds.
# These files are either not needed in the image or should never be there.

# Dependencies — always regenerated by RUN npm install
node_modules

# Secrets — must NEVER be baked into an image
.env

# Git internals — not needed at runtime
.git
.gitignore

# Documentation — not needed at runtime
README.md
CLASS.md

# Editor and OS noise
.DS_Store
.vscode
.idea
*.swp
*.log
