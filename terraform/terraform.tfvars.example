# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is listed in .gitignore — NEVER commit it.
#
# Better pattern: pass sensitive variables via environment variables so they
# never touch the filesystem at all:
#   export TF_VAR_db_password="$(aws secretsmanager get-secret-value --secret-id /jcc/db-password --query SecretString --output text)"

region      = "us-east-1"
environment = "dev"
app_name    = "jcc"

# Set db_password via env var instead of this file:
# export TF_VAR_db_password="your-password-here"
# db_password = "REPLACE_ME"
